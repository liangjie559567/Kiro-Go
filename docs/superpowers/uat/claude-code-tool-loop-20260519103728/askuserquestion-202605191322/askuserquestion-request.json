                }
              },
              "required": ["header", "multiSelect", "options"]
            }
          }
        },
        "required": ["questions"],
        "additionalProperties": false
      }
    }
  ],
  "tool_choice": {"type":"tool","name":"AskUserQuestion"},
  "messages": [
    {"role":"user","content":"Use AskUserQuestion exactly once. Ask whether to run /gsd-ui-phase 46 first or continue plan-phase without UI-SPEC. Use header UI 安全门, multiSelect false, and two options with label and description."}
